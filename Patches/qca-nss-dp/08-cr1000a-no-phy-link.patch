From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: yjy116 <yjy116@gmail.com>
Date: Fri, 22 May 2026 13:40:00 +0800
Subject: [PATCH] net: nss-dp: allow explicit no-phy ports

The Verizon CR1000A connects NSS DP5 to an RTL9303 switch that is
initialized from userspace. It is not a normal MDIO PHY, so phy connection
must be skipped when the device tree explicitly marks the port as no-phy.

The current dataplane open path already forces the link up when there is no
attached phydev. Honor qcom,no-phy in the probe path and prefer explicit
qcom,forced-speed values for no-phy ethtool queries to avoid SSDK speed
polling failures before the userspace switch helper is fully ready.
---
 nss_dp_ethtools.c | 31 ++++++++++++++++++-------------
 nss_dp_main.c     |  4 +++-
 2 files changed, 21 insertions(+), 14 deletions(-)

--- a/nss_dp_ethtools.c
+++ b/nss_dp_ethtools.c
@@ -408,20 +408,25 @@ static int nss_dp_get_ethtool_link_ksett
 		return phy_ethtool_get_link_ksettings(dev, cmd);
 	}
 
-	port_id = dp_priv->macid;
-	/*
-	 * No phydev attached implies a fixed speed link. Read the fixed link speed and duplex from SSDK
-	 */
-	ret = fal_port_speed_get(NSS_DP_ACL_DEV_ID, port_id, &dp_priv->fixed_link_speed);
-	if (ret != SW_OK) {
-		netdev_warn(dev, "Failed to get link speed for ethernet device\n");
-		return -ENODEV;
-	}
+	if (dp_priv->forced_speed) {
+		dp_priv->fixed_link_speed = dp_priv->forced_speed;
+		duplex = dp_priv->forced_duplex;
+	} else {
+		port_id = dp_priv->macid;
+		/*
+		 * No phydev attached implies a fixed speed link. Read the fixed link speed and duplex from SSDK
+		 */
+		ret = fal_port_speed_get(NSS_DP_ACL_DEV_ID, port_id, &dp_priv->fixed_link_speed);
+		if (ret != SW_OK) {
+			netdev_warn(dev, "Failed to get link speed for ethernet device\n");
+			return -ENODEV;
+		}
 
-	ret = fal_port_duplex_get(NSS_DP_ACL_DEV_ID, port_id, &duplex);
-	if (ret != SW_OK) {
-		netdev_warn(dev, "Failed to get duplex for ethernet device\n");
-		return -ENODEV;
+		ret = fal_port_duplex_get(NSS_DP_ACL_DEV_ID, port_id, &duplex);
+		if (ret != SW_OK) {
+			netdev_warn(dev, "Failed to get duplex for ethernet device\n");
+			return -ENODEV;
+		}
 	}
 
 	switch (dp_priv->fixed_link_speed) {
--- a/nss_dp_main.c
+++ b/nss_dp_main.c
@@ -1066,7 +1066,9 @@ static int32_t nss_dp_probe(struct platf
 
 	dp_priv->drv_flags |= NSS_DP_PRIV_FLAG(INIT_DONE);
 
-	if (of_find_property(np, "phy-handle", NULL) || of_phy_is_fixed_link(np)) {
+	if (of_property_read_bool(np, "qcom,no-phy")) {
+		netdev_info(netdev, "no PHY configured, link will be forced up\n");
+	} else if (of_find_property(np, "phy-handle", NULL) || of_phy_is_fixed_link(np)) {
 		dp_priv->phydev = of_phy_get_and_connect(netdev, np,
 				&nss_dp_adjust_link);
 		if (IS_ERR_OR_NULL(dp_priv->phydev)) {
